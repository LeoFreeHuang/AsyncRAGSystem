# ============================================================
# AsyncRAGSystem 环境变量配置
# ============================================================

# --- 服务端配置 ---
HOST=0.0.0.0
PORT=8000
WORKERS=4

# --- Ollama 配置 ---
OLLAMA_HOST=http://localhost:11434
EMBEDDING_MODEL=bge-m3
LLM_MODEL=qwen3.5:9b

# --- Milvus 向量数据库配置 ---
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TOKEN=root:Milvus
MILVUS_COLLECTION=rag_documents
MILVUS_ANALYZER=chinese

# --- BM25 混合检索配置 ---
HYBRID_DENSE_WEIGHT=0.6
HYBRID_RRF_K=60

# --- Redis 缓存配置 ---
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0
REDIS_PASSWORD=
CACHE_EXACT_TTL=3600
CACHE_SEMANTIC_TTL=1800
CACHE_ENABLED=true

# --- 文档分块策略 ---
CHUNK_SIZE=512
CHUNK_OVERLAP=128

# --- 检索策略 ---
TOP_K=5
SIMILARITY_THRESHOLD=0.3

# --- LLM生成参数 ---
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=120
