# ============================================================
# AsyncRAGSystem 环境变量配置模板
# 复制此文件为 .env 并根据本地环境修改
# ============================================================

# --- 服务端配置 ---
HOST=0.0.0.0
PORT=8000
# uvicorn workers数量: 建议 CPU核心数*2, 不超过 (64G RAM / 每worker内存占用)
WORKERS=4

# --- Ollama 配置 (本地大模型服务) ---
OLLAMA_HOST=http://localhost:11434
# 嵌入模型 (用于文本向量化, 推荐: bge-m3 / nomic-embed-text / mxbai-embed-large)
EMBEDDING_MODEL=bge-m3
# 大语言模型 (用于答案生成)
LLM_MODEL=qwen3.5:9b

# --- Milvus 向量数据库配置 ---
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TOKEN=root:Milvus
# 向量存储的集合名称
MILVUS_COLLECTION=rag_documents
# Milvus 文本分析器: standard / english / chinese
MILVUS_ANALYZER=chinese

# --- BM25 混合检索配置 ---
# 语义向量权重 (0~1), BM25权重 = 1 - 此值
HYBRID_DENSE_WEIGHT=0.6
# RRF 融合算法 k 参数
HYBRID_RRF_K=60

# --- Redis 缓存配置 ---
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0
REDIS_PASSWORD=
# 精确匹配缓存过期时间 (秒)
CACHE_EXACT_TTL=3600
# 语义缓存过期时间 (秒)
CACHE_SEMANTIC_TTL=1800
# 是否启用缓存 (false 可完全禁用)
CACHE_ENABLED=true

# --- 文档分块策略 ---
# 每个文本块的最大字符数
CHUNK_SIZE=512
# 相邻文本块的重叠字符数 (保持上下文连贯)
CHUNK_OVERLAP=128

# --- 检索策略 ---
# 检索时返回的最相关文档片段数量
TOP_K=5
# 相似度阈值 (0~1), 低于此值的结果将被过滤
SIMILARITY_THRESHOLD=0.3

# --- LLM生成参数 ---
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=120
